import { ElevatedCard } from "../material/material.slint";
import {
    Vertical,
    MaterialText,
    Icon,
    ScrollView,
} from "../material/material.slint";
import {
    NavigationDrawer,
} from "../material/ui/components/navigation_drawer.slint";

import {
    NavigationItem,
} from "../material/ui/items/navigation_item.slint";

import { DevicesStoreSlint } from "./stores/devices-stores.slint";
import { Button } from "std-widgets.slint";
import {
    PeripheralNavigationGroupTemplate,
} from "navigations/peripheral_navigation_group_template.slint";
import {
    MaterialTypography,
} from "../material/ui/styling/material_typography.slint";
import { Icons } from "icons/icons.slint";

export component SideNavigation inherits Vertical {
    width: 500px;
    height: 800px;

    HorizontalLayout {
        VerticalLayout {
            alignment: center;
            Icon {
                source: Icons.bluetooth;
                height: 30px;
                width: 30px;
            }
        }

        MaterialText {
            text: "Available Adapter";
            style: MaterialTypography.title_large_bold;
        }
    }

    ScrollView {
        VerticalLayout {
            alignment: start;

            for adapter in ["hci0", "hci1", "hci2", "hci3", "hci4", "hci5"]: PeripheralNavigationGroupTemplate {
                title: adapter + " Devices";
                peripherals: [
                    {
                        localname: "Infinix hahahihi",
                        peripheralId: "1232",
                        address: "askdfjls-asdfljasdf-j",
                        isConnected: true,
                        rssi:-20,
                    },
                    {
                        localname: "Carga",
                        peripheralId: "1234",
                        address: "askdfjls-asdfljasdf-j",
                        isConnected: false,
                        rssi:-19,
                    },
                ];
            }
        }
    }
}
